# ============================================
# AICodeAgent V3 — 环境变量模板
# 复制为 .env 后按需修改，不要在版本控制中提交真实密钥
# ============================================

# ===== Android 工程根目录（安装器写入；与 app/ 同级）=====
# export AGENT_ANDROID_ROOT=$HOME/Projects/MyAndroidApp

# ===== Claude CLI 编码引擎（必选） =====
export CLAUDE_CODE_AUTO_ALLOW_BASH=true
# export ANTHROPIC_BASE_URL=http://127.0.0.1:4000
# export ANTHROPIC_API_KEY=sk-...
export CLAUDE_MODEL=claude-sonnet-4-6
export CLAUDE_CODE_MAX_RETRY=2
export CLAUDE_RETRY_DELAY=3.0

# ===== Android 工具链（必选） =====
export ANDROID_HOME=$HOME/Library/Android/sdk
export JAVA_HOME=/Applications/Android\ Studio.app/Contents/jbr/Contents/Home

# ===== Gradle 性能优化（可选） =====
export GRADLE_OPTS="-Dorg.gradle.daemon=true -Dorg.gradle.parallel=true -Dorg.gradle.jvmargs=-Xmx8g"

# ===== GitHub CLI（可选，用于自动 PR） =====
# export GH_TOKEN=ghp_xxxxxxxx

# ===== Web API 认证（生产建议设置） =====
export AGENT_API_KEY=your-secret-change-me

# ===== Telegram Bot（可选，通知用） =====
export TELEGRAM_BOT_TOKEN=your_bot_token
export TELEGRAM_CHAT_ID=your_chat_id

# ===== Figma（UI 类任务需要） =====
export FIGMA_TOKEN=figma_personal_access_token

# ===== 编排超时 / 重试（V3） =====
export AGENT_DEBATE_TIMEOUT=600
export AGENT_SINGLE_TIMEOUT=300
export AGENT_DEBATE_MAX_RETRY=1
export AGENT_CONSENSUS_MAX_RETRY=2
export CODEX_REVIEW_MAX_RETRY=2
export ACCEPTANCE_REVIEW_MAX_RETRY=2
export AGENT_CLARIFICATION_TIMEOUT_HOURS=48
export AGENT_TASK_TOTAL_TIMEOUT=7200

# ===== Codex 审查（可选；未设置则回退 claude --print） =====
# export CODEX_CMD="codex exec -a never --"
export CODEX_REVIEW_TIMEOUT=900

# ===== 日志级别（可选） =====
export AGENT_LOG_LEVEL=INFO

# ===== Code Review Graph（可选） =====
export CRG_AUTO_START=1
export CRG_HTTP_URL=http://127.0.0.1:5555
export CRG_HTTP_PORT=5555

# ===== 调试开关（开发用） =====
# export AGENT_SKIP_CLARIFICATION=1
